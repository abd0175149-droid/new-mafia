# 🎭 Unified Mafia Platform — Environment
# ══════════════════════════════════════════

# Server
NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://mafia_user:mafia_pass@localhost:5432/mafia_db

# Redis
REDIS_URL=redis://localhost:6379

# Authentication (JWT)
JWT_SECRET=change-me-in-production-use-strong-secret
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
